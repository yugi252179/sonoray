{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:start": "electron .",
    "desktop:build": "next build && electron-packager . SonorayERP --platform=win32 --arch=x64 --out=dist --overwrite"
  },
  "build": {
